# PostgreSQL (Supabase)
# Pooler — runtime de la app (puerto 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa — CLI Prisma / migraciones (puerto 5432)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Better Auth
BETTER_AUTH_SECRET="generar-con-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# N8N — Flujo 1: generar preguntas
N8N_WEBHOOK_GENERATE_INTERVIEW_URL="https://tu-n8n.com/webhook/generate-interview"

# ElevenLabs — TTS preguntas en vivo (backend)
ELEVENLABS_API_KEY="tu-api-key"
ELEVENLABS_VOICE_ID="tu-voice-id"

# Mock local sin N8N (opcional)
# NEXT_PUBLIC_USE_MOCK_INTERVIEW="true"
